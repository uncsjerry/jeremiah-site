rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // WHY: Only these specific accounts should have write access — "any authenticated user"
    // was too broad and would let anyone with a Google account modify the database.
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        'jeremiah@uncs.com',
        'fiveacts@gmail.com'
      ];
    }

    match /posts/{postId} {
      // Anyone can read (public feed)
      allow read: if true;
      // Only admin accounts can write
      allow create, update, delete: if isAdmin();
    }

    match /photos/{photoId} {
      // WHY: Public read so the gallery page can display published photos without auth
      allow read: if true;
      // WHY: Admin-only write so only authorized accounts can publish/edit/remove photos
      allow create, update, delete: if isAdmin();
    }

    match /config/{docId} {
      // WHY: Public read for category list used by the gallery filter bar
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
